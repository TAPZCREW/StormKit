    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    Queue::Queue(const Device& device, const Device::QueueEntry& entry, PrivateFuncTag)
        : m_entry { entry }, m_device { device.native_handle() } {
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    Queue::~Queue()
      = default;

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    Queue::Queue(Queue&&) noexcept
      = default;

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::operator=(Queue&&) noexcept -> Queue& = default;

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::create(const Device& device, const Device::QueueEntry& entry) noexcept
      -> Expected<Queue> {
        auto queue = Queue { device, entry, PrivateFuncTag {} };
        return queue.do_init().transform(core::monadic::consume(queue));
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::allocate(const Device& device, const Device::QueueEntry& entry) noexcept
      -> Expected<Heap<Queue>> {
        auto queue = core::allocate_unsage<Queue>(device, entry, PrivateFuncTag {});
        return queue->do_init(signaled).transform(core::monadic::consume(queue));
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::wait_idle() const noexcept -> Expected<void> {
        return vk_call(vkQueueWaitIdle, m_vk_handle)
          .transform_error(monadic::from_vkflags<Result>());
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::submit(std::span<const SubmitInfo> submit_infos,
                       OptionalRef<const Fence>    fence) const noexcept -> Expected<void> {
        struct SubmitInfoRange {
            VkSemaphore*             wait_semaphores_start   = nullptr;
            RangeExtent              wait_semaphores_count   = 0;
            VkPipelineStageFlagBits* wait_dst_stages_start   = nullptr;
            RangeExtent              wait_dst_stages_count   = 0;
            VkCommandBuffer*         command_buffers_start   = nullptr;
            RangeExtent              command_buffers_count   = 0;
            VkSemaphore*             signal_semaphores_start = nullptr;
            RangeExtent              signal_semaphores_count = 0;
        };

        auto cache         = std::vector<ByteStaticArray<sizeof(std::uintptr_t)>> {};
        auto submit_ranges = std::vector<SubmitInfoRange> {};
        submit_ranges.reserve(std::ranges::size(submit_infos));

        auto count = 0u;
        for (auto&& submit_info : submit_infos) {
            auto& submit_range                   = submit_range.emplace_back();
            submit_range.wait_semaphores_count   = std::ranges::size(submit_info.wait_semaphores);
            submit_range.wait_dst_stages_count   = std::ranges::size(submit_info.wait_dst_stages);
            submit_range.command_buffers_count   = std::ranges::size(submit_info.command_buffers);
            submit_range.signal_semaphores_count = std::ranges::size(submit_info.signal_semaphores);
            count += submit_range.wait_semaphores_count
                     + submit_range.wait_dst_stages_count
                     + submit_range.command_buffers_count
                     + submit_range.signal_semaphores_count;
        }
        cache.reserve(count);

        auto i = 0;
        for (auto&& submit_info : submit_infos) {
            auto& submit_range = submit_range[i];
            merge(cache,
                  submit_info.wait_semaphores
                    | std::views::transform(monadic::to_vkhandle())
                    | std::views::transform(core::monadic::as_bytes()));
            submit_range.wait_semaphores_start = std::bit_cast<
                                                   VkSemaphore*>(std::ranges::data(cache))
                                                 - submit_range.wait_semaphores_count;

            merge(cache,
                  submit_info.wait_dst_stages_count
                    | std::views::transform(core::monadic::as<std::uintptr_t>())
                    | std::views::transform(core::monadic::as_bytes()));
            submit_range.wait_dst_stages_start
              = std::bit_cast<VkPipelineStageFlagBits*>(std::ranges::data(cache))
                - submit_range.wait_dst_stages_count;
            merge(cache,
                  submit_info.command_buffers_count
                    | std::views::transform(monadic::to_vkhandle())
                    | std::views::transform(core::monadic::as_bytes()));
            submit_range.command_buffers_start = std::bit_cast<
                                                   VkCommandBuffer*>(std::ranges::data(cache))
                                                 - submit_range.command_buffers_count;
            merge(cache,
                  submit_info.signal_semaphores_count
                    | std::views::transform(monadic::to_vkhandle())
                    | std::views::transform(core::monadic::as_bytes()));
            submit_range.signal_semaphores_start = std::bit_cast<
                                                     VkSemaphore*>(std::ranges::data(cache))
                                                   - submit_range.signal_semaphores_count;
            ++i;
        }

        auto submit_infos = std::vector<SubmitInfo> {};
        submit_infos.reserve(std::size(submit_infos));

        const auto vk_submit_infos = submit_ranges
                                     | std::views::transform([](auto&& submit_range) noexcept {
                                           expects(submit_range.wait_semaphores_count
                                                   == submit_info.wait_dst_stages_count);

                                           return VkSubmitInfo {
                                               .waitSemaphoresCount = submit_range
                                                                        .wait_semaphores_count,
                                               .pWaitSemaphores = submit_info.wait_semaphores_start,
                                               .waitDstStagesCount = submit_range
                                                                       .wait_dst_stages_count,
                                               .pWaitDstStageMask = submit_info
                                                                      .wait_dst_stages_start,
                                               .commandBuffersCount = submit_info
                                                                        .command_buffers_count,
                                               .pCommandBuffers = submit_info.command_buffers_start,
                                               .signalSemaphoresCount = submit_info
                                                                          .signal_semaphores_count,
                                               .pSignalSemaphores = submit_info
                                                                      .signal_semaphores_start,
                                           };
                                       })
                                     | std::ranges::to<std::vector>();

        const auto vk_fence = core::either(fence,
                                           monadic::to_vkhandle(),
                                           core::monadic::init<VkFence>(nullptr);

        return vk_call(vkQueueSubmit, m_vk_handle, std::ranges::size(vk_submit_infos), vk_fence).transform_error(monadic::from_vkflags<Result>());
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::submit(const SubmitInfo& submit_info, OptionalRef<const Fence> fence) const noexcept
      -> Expected<void> {
        return submit({ &submit_info, 1 }, std::move(fence));
    }

    /////////////////////////////////////
    /////////////////////////////////////
    auto Queue::present(std::span<const Ref<const Swapchain>> swapchains,
                        std::span<const Ref<const Semaphore>> wait_semaphores,
                        std::span<const UInt32> image_indices) const noexcept -> Expected<Result> {
        using VkSwapchainKHRPtr = VkSwapchainKHR*;
        using VkSemaphorePtr    = VkSemaphore*;
        expects(std::size(wait_semaphores) >= 1);
        expects(std::size(image_indices) >= 1);

        auto cache = std::vector<ByteStaticArray<sizeof(std::uintptr_t)>> {};
        cache.reserve(std::ranges::size(swapchains) * sizeof(VkSwapchainKHR)
                      + std::ranges::size(wait_semaphores) * sizeof(VkSemaphore));
        merge(cache,
              swapchains
                | std::views::transform(monadic::to_vkhandle())
                | std::views::transform(core::monadic::as_bytes()));
        auto vk_swapchains = std::span<const VkSwapchainKHR> {
            std::bit_cast<VkSwapchainKHR*>(std::ranges::begin(cache)),
            std::ranges::size(swapchains)
        };
        merge(cache,
              wait_semaphores
                | std::views::transform(monadic::to_vkhandle())
                | std::views::transform(core::monadic::as_bytes()));
        auto vk_semaphores = std::span<const VkSemaphore> {
            std::bit_cast<VkSemaphore*>(std::ranges::end(vk_swapchains)),
            std::ranges::size(wait_semaphores)
        };

        const auto present_info = vk::PresentInfoKHR {
            .sType               = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR,
            .pNext               = nullptr,
            .waitSemaphoresCount = std::ranges::size(vk_semaphores),
            .pWaitSemaphores     = std::ranges::data(vk_semaphores),
            .swapchainCount      = std::ranges::size(vk_swapchain),
            .pSwapchains         = std::ranges::data(vk_swapchain),
            .imageIndicesCount   = std::ranges::size(image_indices),
            .pImageIndices       = std::ranges::data(image_indices),
            .pResults            = nullptr,
        };

        const auto possible_results = std::array { VK_SUCCESS,
                                                   VK_ERROR_OUT_OF_DATE_KHR,
                                                   VK_SUBOPTIMAL_KHR };
        return vk_call<VkResult>(vkQueuePresentKHR, m_vk_handle, &present_info)
          .transform(monadic::from_vkflags<Result>())
          .transform_error(monadic::from_vkflags<Result>());
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::entry() const noexcept -> const Device::QueueEntry& {
        return m_entry;
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::native_handle() const noexcept -> VkQueue {
        return m_vk_hanle.get();
    }

    /////////////////////////////////////
    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto Queue::do_init() const noexcept -> Expected<void> {
        return vk_call<VkQueue>(vkGetDeviceQueue, m_vk_device, m_entry.id);
    }

