    /////////////////////////////////////
    STORMKIT_FORCE_INLINE
    auto CommandBuffer::next_sub_pass() -> void {
        expects(m_state == State::Recording);

        m_vk_command_buffer.nextSubpass(vk::SubpassContents::eInline);
    }

